DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=camu_portal

# Resend Email API - https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=CAMU 2.0 Student Portal <onboarding@resend.dev>
# While using onboarding@resend.dev, Resend only allows delivery to your Resend account email.
RESEND_TEST_EMAIL=your-resend-account@gmail.com

# Production: verify a domain at https://resend.com/domains, then switch to:
# RESEND_FROM=CAMU 2.0 Student Portal <notifications@yourdomain.com>
# Remove RESEND_TEST_EMAIL to send directly to logged-in student emails.
